#!/usr/bin/env bash
# quaid - Total Recall memory system CLI
#
# Usage:
#   quaid search "query" --owner quaid
#   quaid store "fact" --owner quaid
#   quaid stats
#   quaid get-edges <node_id>
#   quaid janitor --task all --dry-run
#   quaid docs search "query"
#   quaid docs check
#   quaid registry list --project quaid
#   quaid doctor
#   quaid config [show|edit|path|set <key> <value>]
#   quaid help
#
# This is a convenience wrapper around the Python modules.

set -euo pipefail

# Resolve symlinks to find the real plugin directory
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CMD="${1:-help}"
shift 2>/dev/null || true

# Ensure adapter config discovery has a canonical root.
# Quaid core resolves config from QUAID_HOME/config/memory.json.
if [[ -z "${QUAID_HOME:-}" && -n "${CLAWDBOT_WORKSPACE:-}" ]]; then
  export QUAID_HOME="$CLAWDBOT_WORKSPACE"
fi
if [[ -z "${CLAWDBOT_WORKSPACE:-}" && -n "${QUAID_HOME:-}" ]]; then
  export CLAWDBOT_WORKSPACE="$QUAID_HOME"
fi
if [[ -z "${QUAID_HOME:-}" ]]; then
  ROOT_CANDIDATE="$(cd "$SCRIPT_DIR/../.." && pwd)"
  if [[ -f "$ROOT_CANDIDATE/config/memory.json" ]]; then
    export QUAID_HOME="$ROOT_CANDIDATE"
    export CLAWDBOT_WORKSPACE="$ROOT_CANDIDATE"
  fi
fi

# Ensure Python can import Quaid modules when invoked from any cwd.
if [[ -z "${PYTHONPATH:-}" ]]; then
  export PYTHONPATH="$SCRIPT_DIR"
elif [[ ":${PYTHONPATH}:" != *":${SCRIPT_DIR}:"* ]]; then
  export PYTHONPATH="${SCRIPT_DIR}:${PYTHONPATH}"
fi

case "$CMD" in
  # Lifecycle hooks (adapter-agnostic)
  hook-inject)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" inject "$@"
    ;;
  hook-inject-compact)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" inject-compact "$@"
    ;;
  hook-extract)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" extract "$@"
    ;;
  hook-search)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" search "$@"
    ;;
  hook-session-init)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" session-init "$@"
    ;;
  hook-subagent-start)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" subagent-start "$@"
    ;;
  hook-subagent-stop)
    exec python3 "$SCRIPT_DIR/core/interface/hooks.py" subagent-stop "$@"
    ;;

  # Extraction daemon
  daemon)
    exec python3 "$SCRIPT_DIR/core/extraction_daemon.py" "$@"
    ;;

  # Janitor commands
  janitor)
    exec python3 "$SCRIPT_DIR/core/lifecycle/janitor.py" "$@"
    ;;

  # Session commands
  session)
    exec python3 "$SCRIPT_DIR/ingest/session_logs_ingest.py" "$@"
    ;;

  # Domain management
  domain)
    SUBCMD="${1:-list}"
    shift 2>/dev/null || true
    case "$SUBCMD" in
      list)     exec python3 -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR')
from core.interface.api import list_domains
import json
print(json.dumps(list_domains(), indent=2))
" "$@" ;;
      register) exec python3 -c "
import sys; sys.path.insert(0, '$SCRIPT_DIR')
from core.interface.api import register_domain
import json
name = sys.argv[1] if len(sys.argv) > 1 else ''
desc = sys.argv[2] if len(sys.argv) > 2 else ''
if not name:
    print('Usage: quaid domain register <name> [description]', file=sys.stderr)
    sys.exit(1)
print(json.dumps(register_domain(name, desc), indent=2))
" "$@" ;;
      *)        echo "Usage: quaid domain {list|register <name> [description]}"; exit 1 ;;
    esac
    ;;

  # Docs subsystem
  docs)
    SUBCMD="${1:-help}"
    shift 2>/dev/null || true
    case "$SUBCMD" in
      search)  exec python3 "$SCRIPT_DIR/datastore/docsdb/rag.py" search "$@" ;;
      list)    exec python3 "$SCRIPT_DIR/datastore/docsdb/registry.py" list "$@" ;;
      check)   exec python3 "$SCRIPT_DIR/datastore/docsdb/updater.py" check "$@" ;;
      update)  exec python3 "$SCRIPT_DIR/datastore/docsdb/updater.py" update-stale "$@" ;;
      changelog) exec python3 "$SCRIPT_DIR/datastore/docsdb/updater.py" changelog "$@" ;;
      *)       echo "Usage: quaid docs {search|list|check|update|changelog} [args...]"; exit 1 ;;
    esac
    ;;

  # Registry/projects subsystem (docs registry)
  registry)
    exec python3 "$SCRIPT_DIR/datastore/docsdb/registry.py" "$@"
    ;;

  # Project system (project registry, shadow git, sync)
  project|projects)
    exec python3 "$SCRIPT_DIR/core/project_registry_cli.py" "$@"
    ;;

  # Global project registry (cross-instance tracking)
  global-registry)
    exec python3 "$SCRIPT_DIR/lib/project_registry.py" "$@"
    ;;

  # Project updater
  updater)
    exec python3 "$SCRIPT_DIR/datastore/docsdb/project_updater.py" "$@"
    ;;

  # Compatibility check
  compat|compatibility)
    exec python3 -c "
import sys, json; sys.path.insert(0, '$SCRIPT_DIR')
from core.compatibility import (
    read_circuit_breaker, HostInfo, preflight_compatibility_check,
    fetch_compatibility_matrix, evaluate_compatibility, _parse_version,
    NORMAL, DEGRADED, SAFE_MODE,
)
from lib.adapter import get_adapter

subcmd = sys.argv[1] if len(sys.argv) > 1 else 'status'

if subcmd == 'status':
    adapter = get_adapter()
    data_dir = adapter.data_dir()
    breaker = read_circuit_breaker(data_dir)
    info = adapter.get_host_info()
    print(f'Host: {info.label()}')
    print(f'Binary: {info.binary_path or \"unknown\"}')
    print(f'Circuit breaker: {breaker.status}')
    if breaker.message:
        print(f'Message: {breaker.message}')
    if breaker.reason:
        print(f'Reason: {breaker.reason}')
elif subcmd == 'check':
    adapter = get_adapter()
    info = adapter.get_host_info()
    # Read quaid version from package.json
    from pathlib import Path
    pkg = Path('$SCRIPT_DIR') / 'package.json'
    qv = 'unknown'
    if pkg.exists():
        qv = json.loads(pkg.read_text()).get('version', 'unknown')
    result = preflight_compatibility_check(
        info.platform, info.version, qv,
        cache_dir=adapter.data_dir(),
    )
    print(f'Status: {result[\"status\"]}')
    print(f'OK: {result[\"ok\"]}')
    print(f'Message: {result[\"message\"]}')
    if result['fix']:
        print(f'Fix: {result[\"fix\"]}')
elif subcmd == 'matrix':
    adapter = get_adapter()
    matrix = fetch_compatibility_matrix(adapter.data_dir())
    if matrix:
        print(json.dumps(matrix, indent=2))
    else:
        print('No matrix available (fetch failed and no cache)')
        sys.exit(1)
else:
    print('Usage: quaid compat {status|check|matrix}')
    sys.exit(1)
" "$@"
    ;;

# Everything else goes to memory_graph.py
search|store|stats|recall|get-edges|get-node|delete-node|create-edge|delete-edges-by-fact|search-all|search-fts|backfill-hashes|health|event)
    exec python3 "$SCRIPT_DIR/datastore/memorydb/memory_graph.py" "$CMD" "$@"
    ;;

  identity-map)
    exec python3 "$SCRIPT_DIR/datastore/memorydb/identity_map.py" "$@"
    ;;

  doctor)
    exec python3 "$SCRIPT_DIR/datastore/memorydb/memory_graph.py" health "$@"
    ;;

  instances|instance)
    SUBCMD="${1:-list}"
    shift 2>/dev/null || true
    case "$SUBCMD" in
      list)
        python3 - "$@" <<'PYEOF'
import sys, os, json
sys.path.insert(0, os.environ.get("QUAID_MODULE_ROOT", os.path.dirname(os.path.abspath(__file__))))
from lib.instance import list_instances, quaid_home, instance_id as _iid

home = quaid_home()
instances = list_instances()
try:
    current = _iid()
except Exception:
    current = None

if "--json" in sys.argv:
    print(json.dumps({"home": str(home), "current": current, "instances": instances}))
else:
    print(f"Quaid home: {home}")
    print()
    if not instances:
        print("  (no instances found)")
    else:
        for name in instances:
            marker = " *" if name == current else ""
            print(f"  {name}{marker}")
    if current and current not in instances:
        print(f"  {current}  (current — not yet initialised)")
    print()
PYEOF
        ;;
      *)
        echo "Usage: quaid instances list"
        exit 1
        ;;
    esac
    ;;

  config)
    SUBCMD="${1:-show}"
    shift 2>/dev/null || true
    CONFIG_NODE="$SCRIPT_DIR/config_cli.mjs"
    CONFIG_PY="$SCRIPT_DIR/config_cli.py"
    case "$SUBCMD" in
      show|edit|path)
        if [[ -f "$CONFIG_NODE" ]]; then
          exec node "$CONFIG_NODE" "$SUBCMD" "$@"
        fi
        exec python3 "$CONFIG_PY" "$SUBCMD" "$@"
        ;;
      set)
        if [[ -f "$CONFIG_NODE" ]]; then
          exec node "$CONFIG_NODE" set "$@"
        fi
        exec python3 "$CONFIG_PY" set "$@"
        ;;
      *)
        echo "Usage: quaid config [show|edit|path|set <dotted.key> <value>] [--shared | --instance <id>]"
        exit 1
        ;;
    esac
    ;;

  help|--help|-h)
    echo "quaid - Total Recall memory system"
    echo ""
    echo "Memory commands:"
    echo "  search <query>       Search memories (semantic + FTS)"
    echo "  store <text>         Store a new memory"
    echo "  recall <query>       Full recall pipeline (search + rerank + graph)"
    echo "  stats                Database statistics"
    echo "  health               Knowledge base health metrics"
    echo "  doctor               Alias for health"
    echo "  get-node <id>        Get a specific node"
    echo "  get-edges <id>       Get edges for a node"
    echo "  search-all <query>   Search memories + docs"
    echo "  event [subcmd]       Event bus (emit/list/process/capabilities)"
    echo ""
    echo ""
    echo "Sessions:"
    echo "  session list         List recent sessions"
    echo "  session load <id>    Load a session transcript"
    echo ""
    echo "Domains:"
    echo "  domain list          List knowledge domains"
    echo "  domain register      Register a new domain"
    echo ""
    echo "Maintenance:"
    echo "  janitor [args]       Run janitor pipeline"
    echo "  daemon [cmd]         Extraction daemon (start|stop|status|run)"
    echo ""
    echo "Docs:"
    echo "  docs search <query>  Search RAG docs"
    echo "  docs list            List registered docs"
    echo "  docs check           Check doc staleness"
    echo "  docs update --apply  Update stale docs"
    echo "  docs changelog       View update history"
    echo ""
    echo "Projects:"
    echo "  project list         List registered projects"
    echo "  project create       Create a new project"
    echo "  project show <name>  Show project details"
    echo "  project link <name>  Add current instance to an existing project"
    echo "  project unlink <name> Remove current instance from a project"
    echo "  project delete       Delete a project (unlinks all instances)"
    echo "  project snapshot     Take shadow git snapshot(s)"
    echo "  project sync         Sync files to adapter workspaces"
    echo "  registry [cmd]       Doc registry CLI"
    echo "  global-registry [cmd] Cross-instance project registry"
    echo "  updater [cmd]        Project event processor"
    echo ""
    echo "Hooks:"
    echo "  hook-inject          Inject memories on user prompt"
    echo "  hook-inject-compact  Re-inject after compaction"
    echo "  hook-extract         Extract knowledge from transcript"
    echo "  hook-search <query>  Search memories + docs"
    echo "  hook-session-init    Inject project docs at session start"
    echo "  hook-subagent-start  Register subagent in registry"
    echo "  hook-subagent-stop   Mark subagent complete in registry"
    echo ""
    echo "Compatibility:"
    echo "  compat status        Show host version and circuit breaker state"
    echo "  compat check         Run compatibility preflight check"
    echo "  compat matrix        Show cached compatibility matrix"
    echo ""
    echo "Config:"
    echo "  instances list       List all Quaid instances under QUAID_HOME"
    echo ""
    echo "Config:"
    echo "  config [show]        Show config summary (default: shared or current instance)"
    echo "  config edit          Interactive config editor"
    echo "  config path          Show active config file path"
    echo "  config set k v       Set value by dotted key path"
    echo "  --shared             Target machine-wide shared config (embeddings, ollama)"
    echo "  --instance <id>      Target a specific instance's config"
    echo ""
    echo "Run from: $SCRIPT_DIR"
    ;;

  *)
    exec python3 "$SCRIPT_DIR/datastore/memorydb/memory_graph.py" "$CMD" "$@"
    ;;
esac
