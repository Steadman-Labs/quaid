# Optional override for where bootstrap lives (default: ~/quaid/bootstrap)
# QUAID_BOOTSTRAP_ROOT=/Users/you/quaid/bootstrap

# Optional override for profile files used by the E2E runner.
# QUAID_E2E_PROFILE_SRC=/Users/you/quaid/bootstrap/profiles/runtime-profile.local.quaid.json
# QUAID_E2E_PROFILE_TEST=/Users/you/quaid/bootstrap/profiles/runtime-profile.local.quaid.json
# QUAID_E2E_PROFILE_PATH=/Users/you/quaid/bootstrap/profiles/runtime-profile.local.quaid.json

# Optional OpenClaw ref override for bootstrap/e2e runtime.
# Default in runner is currently v2026.3.7.
# QUAID_E2E_OPENCLAW_REF=v2026.3.7

# Optional API keys if your bootstrap/profile setup resolves auth from env.
# Required for --auth-path openai-api
# OPENAI_API_KEY=
# Required for --auth-path anthropic-api
# ANTHROPIC_API_KEY=
